# 环境变量示例文件
# 复制本文件为 .env 并填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，不会进入版本库

# ===== 大模型 API =====
# 用于 app_config.yaml 中 llm.api_key: ${oc.env:LLM_API_KEY}
# 当前 model= MiniMax-M3，base_url=https://api.minimaxi.com/v1
LLM_API_KEY=sk-cp-your-minimax-key-here

# ===== 数据库密码 =====
# 用于 conf/app_config.yaml 中 db_meta/db_dw 的 password
# 以及 docker/docker-compose.yaml 中 MYSQL_ROOT_PASSWORD / MYSQL_PASSWORD
# 2026-07-22：统一用 root / 123456（原 didilili/dili123）
DB_PASSWORD=123456

# ===== Redis =====
# 用于 app_config.yaml 中 redis_cfg.url: ${oc.env:REDIS_URL,redis://127.0.0.1:6379/0}
REDIS_URL=redis://127.0.0.1:6379/0

# ===== LangSmith 可观测性（可选，不设则完全跳过，零侵入）=====
# 设了 LANGCHAIN_TRACING_V2=true 后，LangChain/LangGraph 所有 llm.ainvoke /
# chain.ainvoke / graph.astream 自动上报 trace 到 LangSmith UI。
# 覆盖：17 节点主图 + multi-agent 子图完整链路 + 每个 LLM 调用的 token/latency。
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt-your-langsmith-key-here
LANGCHAIN_PROJECT=shopkeeper-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
